#setup kubeconfig
# 1. Create the .kube directory in your home folder
mkdir -p ~/.kube

# 2. Copy the admin config from the secure system directory
sudo cp -i /etc/kubernetes/admin.conf ~/.kube/config

# 3. Change ownership of the file from root to your user account
sudo chown $(id -u):$(id -g) ~/.kube/config

# 1. Generate a clean, default configuration file for containerd
sudo containerd config default | sudo tee /etc/containerd/config.toml > /dev/null

# 2. Tell containerd to explicitly use SystemdCgroup (fixes the sandbox sync errors)
sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/g' /etc/containerd/config.toml

# 3. Restart containerd to load the new operational settings
sudo systemctl restart containerd

# 4. Restart the master node agent to stabilize the control plane
sudo systemctl restart kubelet
